# ==========================
# Telegram / Project
# ==========================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ADMIN_ID=your-admin-user-id-here
TELEGRAM_CHANNEL_ID=your-channel-id-here
PROJECT_NAME=IceGods-TelegramBot
BRAND_NAME=IceGods
VIP_GROUP=@your-vip-group

# ==========================
# Wallets
# ==========================
ETH_MAIN_WALLET=your-eth-wallet-address
SOL_MAIN_WALLET=your-sol-wallet-address
ETH_BACKUP_WALLET=your-eth-backup-wallet
SOL_BACKUP_WALLET=your-sol-backup-wallet
