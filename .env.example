# ==========================
# API Keys
# ==========================
CMC_API_KEY=your-cmc-api-key
ETHERSCAN_API_KEY=your-etherscan-api-key
INFURA_API_KEY=your-infura-api-key
COINGECKO_API_KEY=optional-coingecko-api-key

# ==========================
# Database / Deployment
# ==========================
